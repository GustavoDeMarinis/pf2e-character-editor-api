generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Character {
  id               String                @id @default(cuid())
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deletedAt        DateTime?
  characterName    String
  // assignedUserId is required: when a DM creates a character without an assignee,
  // it is assigned to the DM (an NPC until reassigned).
  ancestry         Ancestry              @relation(fields: [ancestryId], references: [id])
  ancestryId       String
  background       Background?           @relation(fields: [backgroundId], references: [id])
  backgroundId     String?
  createdByUser    User                  @relation("User_createdByUserId_fkey", fields: [createdByUserId], references: [id])
  createdByUserId  String
  assignedUser     User                  @relation("User_assignedUserId_fkey", fields: [assignedUserId], references: [id])
  assignedUserId   String
  level            Int                   @default(1)
  characterClass   CharacterClass        @relation(fields: [characterClassId], references: [id])
  characterClassId String
  ancestryBoost    Attribute[]
  ancestryFlaw     Attribute[]
  backgroundBoost  Attribute[]
  classBoost       Attribute
  languages        Language[]
  skills           CharacterSkillLevel[]
  heritage         Heritage?             @relation(fields: [heritageId], references: [id])
  heritageId       String?
  deity            Deity?                @relation(fields: [deityId], references: [id])
  deityId          String?
  characterFeats      CharacterFeat[]
  characterSpells     CharacterSpell[]
  characterConditions CharacterCondition[]

  @@index([ancestryId])
  @@index([backgroundId])
  @@index([createdByUserId])
  @@index([assignedUserId])
  @@index([characterClassId])
  @@index([heritageId])
  @@index([deityId])
}

model ClassLevelingMap {
  id                        String           @id @default(cuid())
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  deletedAt                 DateTime?
  characterClass            CharacterClass   @relation(fields: [characterClassId], references: [id])
  characterClassId          String
  level                     Int
  attributeIncrease         Boolean
  skillIncrease             Boolean
  skillTraining             Boolean
  ancestryFeat              Boolean
  classFeat                 Boolean
  skillFeat                 Boolean
  unarmoredArmorProficiency Proficiency?
  lightArmorProficiency     Proficiency?
  mediumArmorProficiency    Proficiency?
  heavyArmorProficiency     Proficiency?
  unarmedProficiency        Proficiency?
  simpleWeaponProficiency   Proficiency?
  martialWeaponProficiency  Proficiency?
  advancedWeaponProficiency Proficiency?
  perceptionProficiency     Proficiency?
  fortitudeProficiency      Proficiency?
  reflexProficiency         Proficiency?
  willProficiency           Proficiency?
  specialAbilities          SpecialAbility[]

  @@index([characterClassId])
}

model SpecialAbility {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  name               String
  description        String
  type               String
  characterClass     CharacterClass    @relation(fields: [characterClassId], references: [id])
  characterClassId   String
  classLevelingMap   ClassLevelingMap? @relation(fields: [classLevelingMapId], references: [id])
  classLevelingMapId String?

  @@index([characterClassId])
  @@index([classLevelingMapId])
}

enum Proficiency {
  Untrained
  Trained
  Expert
  Master
  Legendary
}

model Ancestry {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  name           String
  description    String?
  traits         Trait[]
  hitPoints      Int
  size           AncestrySize
  speed          Int
  attributeBoost Attribute[]
  attributeFlaw  Attribute[]
  languages      Language[]
  rarity         Rarity
  characters     Character[]
  heritages      Heritage[]
  feats          Feat[]
}

model Language {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  name        String
  description String?
  ancestries  Ancestry[]
  rarity      Rarity
  characters  Character[]
}

enum AncestrySize {
  Tiny
  Small
  Medium
  Large
  Huge
  Gargantuan
}

enum Attribute {
  Strength
  Dexterity
  Constitution
  Intelligence
  Wisdom
  Charisma
  Free
}

model CharacterClass {
  id               String             @id @default(cuid())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  className        String
  description      String?
  keyAttributes    Attribute[]
  hitPoints        Int
  characters       Character[]
  classLevelingMap ClassLevelingMap[]
  specialAbilities SpecialAbility[]
  feats            Feat[]
  focusSpellGrants FocusSpellGrant[]
}

enum UserRole {
  Admin
  Player
}

model User {
  id                  String      @id @default(cuid())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?
  userEmail           String      @unique
  userName            String      @unique
  password            String
  role                UserRole    @default(Player)
  failedLoginAttempts Int         @default(0)
  lockedUntil         DateTime?
  characters          Character[] @relation("User_assignedUserId_fkey")
  charactersCreated   Character[] @relation("User_createdByUserId_fkey")
  sessions            Session[]
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  refreshHash String
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?

  @@index([userId])
}

model Skill {
  id                  String                @id @default(cuid())
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?
  name                String
  description         String?
  associatedAttribute Attribute
  actions                  Action[]
  characterSkillLevel      CharacterSkillLevel[]
  backgrounds              Background[]
  deities                  Deity[]
  feats                    Feat[]
  ritualsAsSecondaryCheck  Ritual[]
}

model Action {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  name            String
  description     String?
  traits          Trait[]
  skill           Skill       @relation(fields: [skillId], references: [id])
  skillId         String
  actionCost      ActionCost?
  criticalSuccess String?
  success         String?
  failure         String?
  criticalFailure String?
  isUntrained     Boolean

  @@index([skillId])
}

model CharacterSkillLevel {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  character       Character   @relation(fields: [characterId], references: [id])
  characterId     String
  skill           Skill       @relation(fields: [skillId], references: [id])
  skillId         String
  proficiency     Proficiency
  levelItWasTaken Int?

  @@index([characterId])
  @@index([skillId])
}

enum WeaponCategory {
  Simple
  Martial
  Advanced
}

enum WeaponDamageType {
  Bludgeoning
  Slashing
  Piercing
}

enum WeaponType {
  Melee
  Ranged
}

enum WeaponHands {
  One
  Two
}

model WeaponBase {
  id                 String             @id @default(cuid())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  name               String
  description        String?
  category           WeaponCategory
  damageTypes        WeaponDamageType[]
  diceAmount         Int
  diceSize           Int
  criticalDiceAmount Int?
  criticalDiceSize   Int?
  weaponGroup        WeaponGroup        @relation(fields: [weaponGroupId], references: [id])
  weaponGroupId      String
  traits             Trait[]
  hands              WeaponHands[]
  range              Int?
  bulk               String?
  favoredByDeities   Deity[]            @relation("Deity_favoredWeapons")

  @@index([weaponGroupId])
}

model WeaponGroup {
  id                             String                       @id @default(cuid())
  createdAt                      DateTime                     @default(now())
  updatedAt                      DateTime                     @updatedAt
  deletedAt                      DateTime?
  name                           String
  weaponBases                    WeaponBase[]
  criticalSpecialization         WeaponCriticalSpecialization @relation(fields: [weaponCriticalSpecializationId], references: [id])
  weaponCriticalSpecializationId String

  @@index([weaponCriticalSpecializationId])
}

model Trait {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  name        String
  description String?
  //TODO add Type of Trait And add validation for type to be checked on adding trait to something
  //TODO add value property, this will set the amount of bonifier for traits like, deadly, Thrown etc. 
  weaponBases WeaponBase[]
  armorBases  ArmorBase[]
  ancestries  Ancestry[]
  runes       Rune[]
  actions     Action[]
  heritages   Heritage[]
  backgrounds Background[]
  deities     Deity[]
  feats       Feat[]
  spells      Spell[]
  rituals     Ritual[]
}

model WeaponCriticalSpecialization {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  name         String
  description  String?
  weaponGroups WeaponGroup[]
}

enum Rarity {
  Common
  Uncommon
  Rare
  Secret
}

enum ArmorCategory {
  Unarmored
  Light
  Medium
  Heavy
}

model ArmorBase {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  name         String
  description  String?
  rarity       Rarity
  traits       Trait[]
  category     ArmorCategory
  armorClass   Int
  dexCap       Int
  checkPenalty Int
  speedPenalty Int
  strengthReq  Int
  price        Int
  bulk         String?
  armorGroup   ArmorGroup    @relation(fields: [armorGroupId], references: [id])
  armorGroupId String

  @@index([armorGroupId])
}

model ArmorGroup {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  name        String
  description String?
  armorBases  ArmorBase[]
}

enum RuneItemSubcategory {
  WeaponProperty
  WeaponFundamental
  ArmorProperty
  ArmorFundamental
  Shield
  Accessory
}

model Rune {
  id                  String              @id @default(cuid())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?
  name                String
  description         String?
  rarity              Rarity
  traits              Trait[]
  runeItemSubcategory RuneItemSubcategory
  level               Int                 @default(1)
  price               Int
}

model Heritage {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  name        String
  description String?
  ancestry    Ancestry    @relation(fields: [ancestryId], references: [id])
  ancestryId  String
  traits      Trait[]
  rarity      Rarity
  characters  Character[]

  @@index([ancestryId])
}

model Background {
  id                    String      @id @default(cuid())
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  deletedAt             DateTime?
  name                  String
  description           String?
  rarity                Rarity
  traits                Trait[]
  attributeBoostOptions Attribute[]
  trainedSkill          Skill?      @relation(fields: [trainedSkillId], references: [id])
  trainedSkillId        String?
  trainedLoreName       String?
  characters            Character[]

  @@index([trainedSkillId])
}

enum DeitySanctification {
  None
  HolyOnly
  UnholyOnly
  HolyOrUnholy
}

enum DivineFont {
  Harm
  Heal
  HarmOrHeal
}

model Domain {
  id               String            @id @default(cuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  name             String
  description      String?
  deities          Deity[]           @relation("Deity_domains")
  alternateDeities Deity[]           @relation("Deity_alternate_domains")
  focusSpellGrants FocusSpellGrant[]
}

model Deity {
  id               String              @id @default(cuid())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  name             String
  description      String?
  rarity           Rarity
  edicts           String[]
  anathema         String[]
  divineAttributes Attribute[]
  sanctification   DeitySanctification
  divineFont       DivineFont
  divineSkill      Skill?              @relation(fields: [divineSkillId], references: [id])
  divineSkillId    String?
  favoredWeapons   WeaponBase[]        @relation("Deity_favoredWeapons")
  domains          Domain[]            @relation("Deity_domains")
  alternateDomains Domain[]            @relation("Deity_alternate_domains")
  clericSpells     DeityClericSpell[]
  traits           Trait[]
  characters       Character[]

  @@index([divineSkillId])
}

model DeityClericSpell {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deity     Deity     @relation(fields: [deityId], references: [id])
  deityId   String
  spell     Spell     @relation(fields: [spellId], references: [id])
  spellId   String
  rank      Int

  @@unique([deityId, rank])
  @@index([deityId])
  @@index([spellId])
}

enum FeatType {
  Ancestry
  Class
  Skill
  General
  Archetype
  Bonus
}

enum ActionCost {
  Free
  Reaction
  One
  Two
  Three
  TwoToThree
  OneToThree
  None
}

model Feat {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  name             String
  // TODO: decide whether description should be nullable to allow partial creation,
  // matching the convention used by most other entities (Trait, Ancestry, Heritage, etc.).
  description      String
  featType         FeatType
  level            Int             @default(1)
  actionCost       ActionCost?
  rarity           Rarity
  prerequisites    String?
  frequency        String?
  trigger          String?
  requirements     String?
  traits           Trait[]
  characterFeats   CharacterFeat[]
  ancestry         Ancestry?       @relation(fields: [ancestryId], references: [id])
  ancestryId       String?
  characterClass   CharacterClass? @relation(fields: [characterClassId], references: [id])
  characterClassId String?
  skill            Skill?          @relation(fields: [skillId], references: [id])
  skillId          String?

  @@index([featType, level])
  @@index([ancestryId])
  @@index([characterClassId])
  @@index([skillId])
}

model CharacterFeat {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  character       Character @relation(fields: [characterId], references: [id])
  characterId     String
  feat            Feat      @relation(fields: [featId], references: [id])
  featId          String
  levelItWasTaken Int
  slotType        FeatType

  @@unique([characterId, featId])
  @@index([characterId])
}

enum SpellTradition {
  Arcane
  Divine
  Occult
  Primal
}

enum SpellComponent {
  Verbal
  Somatic
  Material
  Focus
}

enum SpellTargetType {
  None
  Creature
  Object
  Area
  Self
}

enum SpellSaveType {
  Fortitude
  Reflex
  Will
  None
}

enum SpellArea {
  Burst
  Cone
  Line
  Emanation
  Cylinder
  None
}

model Spell {
  id               String             @id @default(cuid())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  name             String
  // TODO: see TODO on Feat.description — same decision applies here.
  description      String
  rank             Int
  isFocus          Boolean            @default(false)
  traditions       SpellTradition[]
  traits           Trait[]
  rarity           Rarity
  components       SpellComponent[]
  actionCost       ActionCost
  castTimeText     String?
  range            String?
  targets          String?
  targetType       SpellTargetType
  areaType         SpellArea
  areaSize         Int?
  duration         String?
  savingThrow      SpellSaveType
  basicSave        Boolean            @default(false)
  heightenings     SpellHeightening[]
  characterSpells  CharacterSpell[]
  clericForDeities DeityClericSpell[]
  focusSpellGrants FocusSpellGrant[]

  @@index([rank])
  @@index([isFocus])
}

enum HeighteningKind {
  Interval // "Heightened (+N)": effect repeats every N ranks above base; bump = N
  FixedRank // "Heightened (Nth)": effect applies at one specific rank; bump = rank
}

model SpellHeightening {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?
  spell     Spell           @relation(fields: [spellId], references: [id])
  spellId   String
  kind      HeighteningKind
  bump      Int
  effect    String

  @@index([spellId])
}

model CharacterSpell {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  character      Character @relation(fields: [characterId], references: [id])
  characterId    String
  spell          Spell     @relation(fields: [spellId], references: [id])
  spellId        String
  isPrepared     Boolean   @default(false)
  preparedAtRank Int?

  // The composite unique covers prepared spells (rank distinguishes duplicates).
  // For "known" spells (preparedAtRank IS NULL) Postgres treats NULLs as distinct,
  // so a partial unique index `(characterId, spellId) WHERE preparedAtRank IS NULL`
  // is added in the migration to prevent duplicate known-spell rows.
  @@unique([characterId, spellId, preparedAtRank])
  @@index([characterId])
}

model Ritual {
  id                   String              @id @default(cuid())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?
  name                 String
  description          String
  rank                 Int
  rarity               Rarity
  traits               Trait[]
  castTime             String
  cost                 String?
  primaryCheck         String
  secondaryCasters     Int                 @default(0)
  secondaryCheckSkills Skill[]
  range                String?
  targets              String?
  duration             String?
  criticalSuccess      String?
  success              String?
  failure              String?
  criticalFailure      String?
  heightenings         RitualHeightening[]

  @@index([rank])
}

model RitualHeightening {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  ritual    Ritual   @relation(fields: [ritualId], references: [id])
  ritualId  String
  fixedRank Int
  effect    String

  @@index([ritualId])
}

model FocusSpellGrant {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  spell            Spell           @relation(fields: [spellId], references: [id])
  spellId          String
  characterClass   CharacterClass? @relation(fields: [characterClassId], references: [id])
  characterClassId String?
  domain           Domain?         @relation(fields: [domainId], references: [id])
  domainId         String?

  @@index([spellId])
  @@index([characterClassId])
  @@index([domainId])
}

model Condition {
  id                  String               @id @default(cuid())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  name                String               @unique
  description         String
  hasValue            Boolean              @default(false)
  overrides           Condition[]          @relation("ConditionOverrides")
  overriddenBy        Condition[]          @relation("ConditionOverrides")
  characterConditions CharacterCondition[]
}

model CharacterCondition {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  character   Character @relation(fields: [characterId], references: [id])
  characterId String
  condition   Condition @relation(fields: [conditionId], references: [id])
  conditionId String
  value       Int?
  source      String?
  appliedAt   DateTime  @default(now())
  expiresAt   DateTime?

  @@index([characterId])
  @@index([conditionId])
}
