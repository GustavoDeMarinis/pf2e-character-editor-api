# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pf2e_db"

# JWT — generate with: openssl rand -hex 64
# Must be at least 64 characters.
JWT_SECRET_KEY="replace-me-with-openssl-rand-hex-64-output"
JWT_ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY_DAYS="30"

# Environment: local | prod
ENV="local"

# CORS — comma-separated list of allowed origins (required in prod)
CORS_ORIGIN="http://localhost:3000"

# Seed default password for dev fixtures
USER_DEFAULT_PASSWORD="DevPassword1!"

# Set to "true" to expose /api-docs in prod (disabled by default)
DOCS_ENABLED="false"
